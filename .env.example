# Copy to .env and tune. All are optional — defaults work.

# Paths (containers use /data; local dev can use ./data)
# SOS_STORAGE_DIR=./data/jobs
# SOS_MODEL_DIR=./data/models

# HTTP
SOS_MAX_UPLOAD_MB=500
SOS_CORS_ORIGINS=["*"]

# Model (drop to yolov8n.pt for low VRAM / CPU)
SOS_MODEL_NAME=yolov8s.pt
SOS_IMGSZ=960
SOS_USE_HALF_PRECISION=true

# Detection thresholds
SOS_CONF_THRESH=0.35
SOS_IOU_THRESH=0.6

# Vehicle speed
SOS_SPEED_LIMIT_KMH=80.0
SOS_FAST_VEHICLE_COUNT=10
SOS_SPEED_WINDOW_SEC=3.0

# Crowd
SOS_CROWD_COUNT=10
SOS_CROWD_RADIUS_M=5.0
SOS_CROWD_SPEED_KMH=8.0

# Alert debouncing
SOS_ALERT_SUSTAIN_FRAMES=8
SOS_ALERT_COOLDOWN_FRAMES=30
